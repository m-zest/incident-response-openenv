# Incident Response SRE Environment
# Copy this file to .env and fill in your values

# --- Baseline LLM Configuration ---
# API key for the OpenAI-compatible provider (Groq, NVIDIA, OpenAI, etc.)
OPENAI_API_KEY=your-api-key-here

# Base URL for the LLM provider
# Groq (free):   https://api.groq.com/openai/v1
# NVIDIA (free):  https://integrate.api.nvidia.com/v1
# OpenAI:         https://api.openai.com/v1
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Model name to use for baseline inference
# Groq:   llama-3.3-70b-versatile
# NVIDIA:  nvidia/llama-3.3-nemotron-super-49b-v1
# OpenAI:  gpt-4o
MODEL_NAME=llama-3.3-70b-versatile

# --- Server Configuration ---
# Host and port for the FastAPI server
HOST=0.0.0.0
PORT=8000
